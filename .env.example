# ============================================================
# claudetrade 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 채워넣으세요
#   cp .env.example .env
# ============================================================


# ────────────────────────────────────────────────────────────
# [1] 한국투자증권 (KIS) API  ← 필수 (한국장 거래)
# 발급: https://apiportal.koreainvestment.com
# ────────────────────────────────────────────────────────────

# 앱 키 / 시크릿
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here

# 계좌번호 (형식: 12345678-01)
KIS_ACCOUNT_NO=12345678-01

# 모의투자 여부 (true = 모의, false = 실계좌)
# 처음에는 반드시 true 로 시작하세요
KIS_IS_PAPER=true

# ── 투자 금액 설정 ──────────────────────────────────────────────────────────
# [모의투자] 가상 시드머니 (원 단위, 기본 1,000만원)
#   - 실제 돈이 아닌 시뮬레이션용 초기 자금
#   - 자신의 실제 계좌 크기와 비슷하게 맞추는 것을 권장
PAPER_CASH=10000000

# [공통] 1회 최대 주문 금액 (원 단위)
#   - 모의투자: 이 값 그대로 사용 (기본 500,000원)
#   - 실계좌:   이 값 vs 총자산 5% 중 더 작은 값으로 자동 결정
#              (예: 총자산 2,000만원 → 5% = 100만원, env=200만원 → 실제 100만원 적용)
MAX_ORDER_KRW=500000

# Execution / risk feature flags (default OFF to preserve legacy behavior)
ENABLE_LIMIT_ORDER=false
LIMIT_ORDER_OFFSET_BPS=5
ENABLE_SLIPPAGE_GUARD=false
MAX_EST_SLIPPAGE_BPS=25
ENABLE_ATR_POSITION_SIZING=false
ATR_TARGET_PCT=0.015
ENABLE_DYNAMIC_UNIVERSE=false
DYNAMIC_UNIVERSE_TOP_N=20

# 트레일링 스탑 (TP 도달 후 추가 상승 추적)
TRAILING_STOP_ENABLED=true    # 트레일링 스탑 ON/OFF (기본 ON)
TRAILING_STOP_PCT=3           # 트레일링 폭 % (기본 3%, 범위 1~10)
TRAILING_ANALYST_ENABLED=false # TP 시 분석가 3명 합의 여부 (기본 OFF)


# ────────────────────────────────────────────────────────────
# [2] Alpha Vantage API  ← 필수 (미국장 시세/캔들)
# 발급: https://www.alphavantage.co/support/#api-key
# 무료 플랜: 분당 5회, 일 500회 제한
# ────────────────────────────────────────────────────────────

ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here


# ────────────────────────────────────────────────────────────
# [3] Anthropic (Claude AI) API  ← 필수
# 발급: https://console.anthropic.com/keys
# 사용 모델: claude-sonnet-4-6
# 하루 예상 비용: 아침 판단(3회) + 튜닝(6회) + 사후분석(1회) ≈ $0.10~0.30/일
# ────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-your_key_here


# ────────────────────────────────────────────────────────────
# [4] Telegram Bot  ← 선택 (알림 없어도 동작은 됨)
# 봇 생성: @BotFather 에게 /newbot 명령
# 채팅 ID 확인: @userinfobot 에게 메시지 전송
# ────────────────────────────────────────────────────────────

TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=your_chat_id_here


# ────────────────────────────────────────────────────────────
# [5] 투자 설정
# PAPER_CASH   : 모의투자 초기 자금 (원), 기본 10,000,000
# MAX_ORDER_KRW: 1회 최대 주문 금액 (원) — KR/US 공유 풀로 동일 적용
# ────────────────────────────────────────────────────────────

PAPER_CASH=10000000
MAX_ORDER_KRW=500000
