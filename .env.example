# ============================================================
# claudetrade 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 채워넣으세요
#   cp .env.example .env
# ============================================================


# ────────────────────────────────────────────────────────────
# [1] 한국투자증권 (KIS) API  ← 필수 (한국장 거래)
# 발급: https://apiportal.koreainvestment.com
# ────────────────────────────────────────────────────────────

# 앱 키 / 시크릿
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here

# 계좌번호 (형식: 12345678-01)
KIS_ACCOUNT_NO=12345678-01

# 모의투자 여부 (true = 모의, false = 실계좌)
# 처음에는 반드시 true 로 시작하세요
KIS_IS_PAPER=true


# ────────────────────────────────────────────────────────────
# [2] Alpha Vantage API  ← 필수 (미국장 시세/캔들)
# 발급: https://www.alphavantage.co/support/#api-key
# 무료 플랜: 분당 5회, 일 500회 제한
# ────────────────────────────────────────────────────────────

ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here


# ────────────────────────────────────────────────────────────
# [3] Anthropic (Claude AI) API  ← 필수
# 발급: https://console.anthropic.com/keys
# 사용 모델: claude-sonnet-4-6
# 하루 예상 비용: 아침 판단(3회) + 튜닝(6회) + 사후분석(1회) ≈ $0.10~0.30/일
# ────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-your_key_here


# ────────────────────────────────────────────────────────────
# [4] Telegram Bot  ← 선택 (알림 없어도 동작은 됨)
# 봇 생성: @BotFather 에게 /newbot 명령
# 채팅 ID 확인: @userinfobot 에게 메시지 전송
# ────────────────────────────────────────────────────────────

TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=your_chat_id_here
