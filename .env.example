# ============================================================
# claudetrade 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 채워넣으세요
#   cp .env.example .env
# ============================================================
#
# ┌─────────────────────────────────────────────────────────┐
# │  모드별 실행 방법                                        │
# │                                                         │
# │  [모의투자]  KIS_IS_PAPER=true  + python trading_bot.py │
# │             KIS 모의투자 APP_KEY 사용                   │
# │             → 한투 앱 모의투자 화면에서 체결 확인 가능  │
# │                                                         │
# │  [실  거래]  KIS_IS_PAPER=false + python trading_bot.py --live
# │             KIS 실거래 APP_KEY 로 교체 필요             │
# │             → 실계좌에서 실제 체결                      │
# │                                                         │
# │  * APP_KEY는 모의투자용/실거래용 별도 발급              │
# │    https://apiportal.koreainvestment.com                │
# └─────────────────────────────────────────────────────────┘


# ────────────────────────────────────────────────────────────
# [1] 한국투자증권 (KIS) API  ← 필수 (한국장 거래)
# 발급: https://apiportal.koreainvestment.com
#
# ※ 모의투자용 키와 실거래용 키는 별도로 발급받아야 합니다.
#    모의투자: 앱 등록 시 "모의투자" 선택 → VTTC 계열 TR 사용
#    실  거래: 앱 등록 시 "실거래"   선택 → TTTC 계열 TR 사용
# ────────────────────────────────────────────────────────────

# ── 모의투자로 시작할 때 ──────────────────────────────────────
# KIS 개발자 포털에서 "모의투자" 앱 등록 후 발급받은 키 입력
# APP_KEY=PSRNWqkd... 같이 모의투자 전용 키가 발급됨
KIS_APP_KEY=your_kis_paper_app_key_here
KIS_APP_SECRET=your_kis_paper_app_secret_here
KIS_ACCOUNT_NO=12345678-01   # 모의투자 계좌번호

# ── 실거래로 전환할 때 ──────────────────────────────────────
# KIS 개발자 포털에서 "실거래" 앱 등록 후 새로 발급받은 키로 교체
# 모의투자 키와 실거래 키는 완전히 별개 — 혼용 불가
# KIS_APP_KEY=your_kis_live_app_key_here
# KIS_APP_SECRET=your_kis_live_app_secret_here
# KIS_ACCOUNT_NO=12345678-01   # 실거래 계좌번호 (모의와 다를 수 있음)

# 모의투자 여부
#   true  → 모의투자 서버(openapivts.koreainvestment.com) + 모의 TR 코드 사용
#   false → 실거래 서버(openapi.koreainvestment.com)     + 실거래 TR 코드 사용
# 처음에는 반드시 true 로 시작하세요
KIS_IS_PAPER=true

# ── 주문 금액 설정 ────────────────────────────────────────────
# 잔고는 KIS에서 직접 조회 (모의투자/실거래 모두 동일)
#
# [공통] 1회 최대 주문 금액 (원 단위)
#   모의투자: 이 값 그대로 사용
#   실  거래: 이 값 vs 총자산 5% 중 더 작은 값으로 자동 결정
#            (예: 총자산 2,000만원 → 5% = 100만원, env=200만원 → 실제 100만원)
MAX_ORDER_KRW=12000000
MAX_ORDER_PCT=0.50

# ── 포지션 한도 ───────────────────────────────────────────────────────────────
MAX_POSITIONS=3          # 동시 보유 최대 종목 수
MAX_PYRAMID=2            # 동일 종목 최대 추가매수 횟수 (1=추가매수 없음)

# ── 모드별 주문 비율 (%) ──────────────────────────────────────────────────────
# Claude 3명 합의 결과에 따라 MAX_ORDER_KRW 대비 이 비율만큼 주문
SIZE_AGGRESSIVE=100
SIZE_MODERATE_BULL=80
SIZE_MILD_BULL=50
SIZE_CAUTIOUS=60
SIZE_NEUTRAL=50
SIZE_MILD_BEAR=30
SIZE_CAUTIOUS_BEAR=20
SIZE_DEFENSIVE=10

# Execution / risk feature flags (default OFF to preserve legacy behavior)
ENABLE_LIMIT_ORDER=false
LIMIT_ORDER_OFFSET_BPS=5
ENABLE_SLIPPAGE_GUARD=false
MAX_EST_SLIPPAGE_BPS=25
ENABLE_ATR_POSITION_SIZING=false
ATR_TARGET_PCT=0.015
ENABLE_DYNAMIC_UNIVERSE=false
DYNAMIC_UNIVERSE_TOP_N=20

# Entry/risk control defaults
KR_DAILY_ENTRY_CAP=2
US_DAILY_ENTRY_CAP=2
KR_CLAUDE_PRICE_NEW_ENTRY_BLOCK=true
KR_CONTINUATION_NEW_ENTRY_BLOCK=true
PLANA_MFE_BREAKEVEN_ENABLED=true
PLANA_MFE_BREAKEVEN_TRIGGER_PCT=2.5
PLANA_MFE_BREAKEVEN_BUFFER_PCT=0.001
US_BROKER_SYNC_QUARANTINE_ENABLED=true
US_BROKER_SYNC_QUARANTINE_RECHECK_SECONDS=60

# 트레일링 스탑 (TP 도달 후 추가 상승 추적)
TRAILING_STOP_ENABLED=true    # 트레일링 스탑 ON/OFF (기본 ON)
TRAILING_STOP_PCT=3           # 트레일링 폭 % (기본 3%, 범위 1~10)
TRAILING_ANALYST_ENABLED=false # TP 시 분석가 3명 합의 여부 (기본 OFF)

# Claude 파라미터 검토 레이어 (4th layer)
CLAUDE_PARAM_REVIEW=false     # adaptive_params 결과를 Claude가 재검토 (기본 OFF)


# ────────────────────────────────────────────────────────────
# [1-US] 미국장 계좌 (실거래 전환 시 KR과 별도 계좌로 운영)
#
# ※ 아직 코드 연결 미완 (RiskManager KR/US 분리 작업 진행 중)
#   현재는 이 값을 설정해도 kis_api.py / trading_bot.py에서 읽지 않음
#   연결 완료 전까지는 채워도 동작에 영향 없음
#
# KIS APP_KEY/SECRET은 KR과 동일 키 사용 (해외주식 권한 포함)
# 계좌번호만 다름 — 한투 앱에서 해외주식 계좌번호 확인 필요
# KIS_IS_PAPER=true 구간에서는 KR 계좌번호로 US 모의투자도 처리됨
# ────────────────────────────────────────────────────────────

# 미국장 전용 계좌번호 (실거래 시 KR과 다를 경우 입력, 같으면 비워도 됨)
KIS_ACCOUNT_NO_US=

# 미국장 전용 APP_KEY/SECRET (보통 KR과 동일 키 — 별도 발급 시에만 입력)
KIS_APP_KEY_US=
KIS_APP_SECRET_US=

# 미국장 모의/실거래 여부 (KR과 독립 설정 가능, 비워두면 KIS_IS_PAPER 따름)
KIS_IS_PAPER_US=

# ── 미국장 리스크 파라미터 (비워두면 KR 설정 사용) ───────────────
# 미국장 1회 최대 주문금액 (원화 기준, 비워두면 MAX_ORDER_KRW 사용)
US_MAX_ORDER_KRW=

# 미국장 최대 동시 보유 종목 수
US_MAX_POSITIONS=3

# 미국장 일일 최대 손실 %
US_MAX_DAILY_LOSS_PCT=

# Stop cluster safety defaults.
# 1st stop: temporary cooldown. 4th stop: market block. 6th stop: disaster block.
STOP_CLUSTER_FIRST_FREEZE_MINUTES=30
STOP_CLUSTER_HARD_BLOCK_COUNT=4
STOP_CLUSTER_DISASTER_BLOCK_COUNT=6


# ────────────────────────────────────────────────────────────
# [2] 미국장 시세 API  ← 필수
#
# ▶ Finnhub (US 현재가 주력)
#   발급: https://finnhub.io  → 무료 회원가입 후 Dashboard에서 API Key 복사
#   무료 플랜: 60회/분, 일 한도 없음
#
# ▶ FMP — Financial Modeling Prep (US 상위종목 스크리너 주력)
#   발급: https://financialmodelingprep.com/developer/docs  → 무료 회원가입 후 Dashboard
#   무료 플랜: 250회/일
#
# ▶ Alpha Vantage (레거시 폴백 — Finnhub+FMP 실패 시에만 사용)
#   발급: https://www.alphavantage.co/support/#api-key
#   무료 플랜: 25회/일 × 2키 (KEY-1 소진 시 KEY-2 자동 전환)
#
# 우선순위: Finnhub/FMP → Alpha Vantage KEY-1 → Alpha Vantage KEY-2
# ────────────────────────────────────────────────────────────

FINNHUB_API_KEY=your_finnhub_key_here
FMP_API_KEY=your_fmp_key_here

# 레거시 폴백
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
ALPHA_VANTAGE_KEY_2=your_second_alpha_vantage_key_here


# ────────────────────────────────────────────────────────────
# [3] Anthropic (Claude AI) API  ← 필수
# 발급: https://console.anthropic.com/keys
# 사용 모델: claude-sonnet-4-6
# 하루 예상 비용: 아침 판단(3회) + 튜닝(6회) + 사후분석(1회) ≈ $0.10~0.30/일
# ────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-your_key_here


# ────────────────────────────────────────────────────────────
# [4] Telegram Bot  ← 선택 (알림 없어도 동작은 됨)
# 봇 생성: @BotFather 에게 /newbot 명령
# 채팅 ID 확인: @userinfobot 에게 메시지 전송
# ────────────────────────────────────────────────────────────

TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=your_chat_id_here


# ────────────────────────────────────────────────────────────
# [5] 기타 선택 API
# ────────────────────────────────────────────────────────────

# DART 공시 API (선택)
# 발급: https://opendart.fss.or.kr
# DART_API_KEY=your_dart_key_here

# 외부 시장 데이터 API (선택)
# DATA_GO_KR_KEY=your_data_go_kr_decoding_key_here
# FRED_API_KEY=your_fred_key_here
# KRX_AUTH_KEY=your_krx_key_here
# BIGKINDS_KEY=your_bigkinds_key_here

# USD/KRW 환율 기본값 (yfinance 조회 실패 시 폴백)
USD_KRW_RATE=1350

# ────────────────────────────────────────────────────────────
# [6] Claude 판단 품질 v2 계약 / 운영 안전장치
# ────────────────────────────────────────────────────────────
EVIDENCE_PACK_ENABLED=true
EVIDENCE_PACK_CEILING_ENABLED=false
EVIDENCE_PACK_PARTIAL_GRACE_MIN=15
KR_EVIDENCE_PACK_ENABLED=true
US_EVIDENCE_PACK_ENABLED=true
CANDIDATE_ACTIONS_V2_ENABLED=true
SOFT_GATE_OVERRIDE_VALIDATION_ENABLED=true
SOFT_GATE_ALLOW_RET3_ONLY_FIRST_MIN=5
ADAPTIVE_LIVE_R3_MIN_KR=0.8
ADAPTIVE_LIVE_R5_MIN_KR=0.0
ADAPTIVE_LIVE_R10_MIN_KR=3.0
ADAPTIVE_LIVE_R30_MIN_KR=8.0
ADAPTIVE_LIVE_PULLBACK_MIN_KR=-3.0
ADAPTIVE_LIVE_R3_MIN_US=0.8
ADAPTIVE_LIVE_R5_MIN_US=0.0
ADAPTIVE_LIVE_R10_MIN_US=3.0
ADAPTIVE_LIVE_R30_MIN_US=8.0
ADAPTIVE_LIVE_PULLBACK_MIN_US=-3.0
UNIFIED_CANDIDATE_POOL_PROMPT_RANK_ENABLED=true
CANDIDATE_QUALITY_TRAINER_ENABLED=true
CANDIDATE_PROMPT_POOL_REORDER_ENABLED=true
CANDIDATE_QUALITY_TRAINER_PROMPT_HINT_ENABLED=true
CANDIDATE_PROMPT_POOL_TARGET_KR=28
CANDIDATE_PROMPT_POOL_TARGET_US=24
CANDIDATE_PROMPT_POOL_HARD_CAP_KR=28
CANDIDATE_PROMPT_POOL_HARD_CAP_US=24
TRAINER_SCORE_VERSION=trainer_quality_v1
TRAINER_PLAN_A_SCORE_MIN=62.0
TRAINER_PLAN_A_RISK_MAX=35.0
TRAINER_PLAN_B_SCORE_MIN=55.0
TRAINER_PLAN_B_RISK_MAX=70.0
TRAINER_WATCH_SCORE_MIN=45.0
TRAINER_WATCH_RISK_MAX=80.0
TRAINER_KR_WEAK_IMMEDIATE_BUCKET_PENALTY=-8.0
TRAINER_KR_WEAK_IMMEDIATE_BUCKET_RISK=8.0
TRAINER_STALE_CYCLE_THRESHOLD=3
TRAINER_STALE_CYCLE_PENALTY=-8.0
CANDIDATE_TRAINER_KR_CHASE_CHANGE_PENALTY=-12.0
CANDIDATE_TRAINER_KR_LATE_CHANGE_PENALTY=-5.0
CANDIDATE_TRAINER_KR_WEAK_IMMEDIATE_BUCKET_PENALTY=-8.0
CANDIDATE_TRAINER_STALE_AGE_PENALTY=-10.0
CANDIDATE_TRAINER_DATA_QUALITY_PENALTY=-40.0
KR_LATE_ENTRY_EXEC_GATE_ENABLED=true
POST_OPEN_FEATURES_LIVE_ENABLED=true
DECISION_ID_FALLBACK_ALERT_RATE=0.2
DECISION_ID_FALLBACK_ALERT_MIN_COUNT=1
EXIT_LIFECYCLE_ALLOWLIST_LIVE_ENABLED=true
EXIT_LIFECYCLE_LIVE_REASONS=recovery_micro_time_stop,recovery_micro_no_carry,pre_close,session_close,broker_mismatch,hard_loss,operator_kill,daily_loss_stop
EXIT_BYPASS_ALERT_RATE=0.3
RECOVERY_MICRO_INVARIANT_ENABLED=true
PROFIT_PRESERVATION_SLA_ENABLED=true
HOLD_ADVISOR_SOFT_CACHE_ENABLED=true
HOLD_ADVISOR_SOFT_CACHE_TTL_SEC=900
HOLD_ADVISOR_SOFT_CACHE_PRICE_MOVE_MAX_PCT=0.2
HOLD_ADVISOR_SOFT_CACHE_PNL_MOVE_MAX_PCT=0.15
PLANA_HOLD_POLICY_MODE=shadow
KR_PLANA_HOLD_POLICY_MODE=shadow
US_PLANA_HOLD_POLICY_MODE=shadow
PLANA_HOLD_POLICY_MIN_VALID_MINUTES=1
PLANA_HOLD_POLICY_MAX_VALID_MINUTES=30
PLANA_HOLD_POLICY_DEFAULT_VALID_MINUTES=5
PLANA_HOLD_POLICY_MAX_RECHECKS=2
PLANA_HOLD_POLICY_HARD_GAP_CAP_KR=0.01
PLANA_HOLD_POLICY_HARD_GAP_CAP_US=0.015
PLANA_HOLD_POLICY_REQUIRE_PROFIT_FLOOR=true
PLANA_HOLD_POLICY_RECREATE_COOLDOWN_MINUTES=3
PLANA_HOLD_POLICY_RECREATE_MIN_PRICE_MOVE_PCT=0.5
HOLD_ADVISOR_LOSS_CAP_CACHE_SHADOW=true
HOLD_ADVISOR_LOSS_CAP_CACHE_LIVE=false
SELECTION_OUTPUT_COMPRESSION_ENABLED=true
CLAUDE_SELECTION_COMPRESSED_MAX_TOKENS=4000
CLAUDE_SELECTION_COMPACT_SCHEMA_ENABLED=true
CLAUDE_SELECTION_COMPACT_WATCH_MAX=15
CLAUDE_SELECTION_COMPACT_TRADE_READY_MAX=5
TUNING_FEEDBACK_CONTRACT_ENABLED=true
TUNING_FEEDBACK_MAX_SIMILAR_FAILURES=3
SELL_IDEMPOTENCY_GUARD_ENABLED=true
CLAUDE_BUDGET_THROTTLE_ENABLED=true
CLAUDE_DAILY_WARN_USD=5.0
CLAUDE_DAILY_BUDGET_USD=8.0
CLAUDE_MONTHLY_BUDGET_USD=120.0
CLAUDE_BUDGET_HARD_EXIT_EXEMPT=true
